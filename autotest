#!/bin/sh

FILE="$1"

if [ -z "$FILE" ]; then
    echo "Usage: $0 <fichier-elf>"
    exit 1
fi

MINE="/tmp/mine_header.txt"
READELF="/tmp/readelf_header.txt"

# Ton programme : on garde les 19 dernières lignes
./Options_and_debug_example -S "$FILE" | tail -n 20 > "$MINE"

# readelf officiel : idem
arm-none-eabi-readelf -S "$FILE" | tail -n 20 > "$READELF"

echo "===== DIFF (readelf vs programme) ====="
diff -u "$READELF" "$MINE"

./Options_and_debug_example -x "$FILE" \
  | grep "^  0x" \
  | grep -Eo '[0-9a-fA-F]{8}' \
  | tr 'A-F' 'a-f' \
  > "$MINE"

# readelf: garder uniquement les groupes hex (8 hex)
arm-none-eabi-readelf -x .text "$FILE" \
  | grep "^  0x" \
  | grep -Eo '[0-9a-fA-F]{8}' \
  | tr 'A-F' 'a-f' \
  > "$READELF"
echo "===== DIFF (groupes hex uniquement) ====="
diff -u "$READELF" "$MINE"
