#!/bin/sh

OPTION="$1"
FILEA="$2"
FILEB="$3"
OUTFILE="$4"

if [ -z "$OPTION" ] || [ -z "$FILEA" ]; then
    echo "Usage:"
    echo "  $0 -S <fichier-elf>"
    echo "  $0 -t <fichier-elf>"
    echo "  $0 -f <fileA.o> <fileB.o> <out.o>"
    exit 1
fi

MINE="/tmp/mine.txt"
READELF="/tmp/readelf.txt"

SECA="/tmp/sections_A.txt"
SECB="/tmp/sections_B.txt"
SECU="/tmp/sections_union.txt"

fail() { echo "❌ FAIL: $*"; exit 1; }
pass() { echo "✅ PASS: $*"; }

# Extrait la liste des sections "utiles" : name type size_hex
# Format readelf --wide -S :
# [Nr] Name Type Addr Off Size ES Flg Lk Inf Al
liste_sections_utiles() {
  F="$1"
  arm-none-eabi-readelf -S --wide "$F" \
    | awk '
      /^\s*\[\s*[0-9]+\]/ {
        name=$2; type=$3; size=$6;
        # ignorer section NULL
        if (name=="") next;
        # ignorer debug
        if (name ~ /^\.debug/) next;
        # ignorer relocations (par nom ou type)
        if (name ~ /^\.rel/ || name ~ /^\.rela/) next;
        if (type=="REL" || type=="RELA") next;
        print name, type, size;
      }'
}

# Récupère type/size d'une section depuis un fichier "sections_*.txt"
get_type() {
  LIST="$1"; NAME="$2"
  awk -v n="$NAME" '$1==n {print $2; exit}' "$LIST"
}
get_size_hex() {
  LIST="$1"; NAME="$2"
  awk -v n="$NAME" '$1==n {print $3; exit}' "$LIST"
}

# Convertit hex "000024" ou "0x24" -> décimal
hex_to_dec() {
  H="$1"
  H=$(echo "$H" | sed 's/^0x//')
  echo $((16#$H))
}

# Vérifie qu'une section existe dans un fichier (via readelf -S)
section_existe() {
  F="$1"; NAME="$2"
  arm-none-eabi-readelf -S --wide "$F" | grep -qE "[[:space:]]$NAME([[:space:]]|$)"
}

# Dump "hex stream" d'une section via readelf -x (PROGBITS)
# On récupère uniquement les groupes hex 8-caractères (mots) et on les concatène.
dump_hex_stream() {
  F="$1"; NAME="$2"
  arm-none-eabi-readelf -x "$NAME" "$F" 2>/dev/null \
    | awk '
      /^\s*0x[0-9a-fA-F]+/ {
        for (i=2; i<=NF; i++) {
          if ($i ~ /^[0-9a-fA-F]{8}$/) printf "%s", $i;
        }
      }
      END { printf "\n"; }'
}

case "$OPTION" in
  -t)
    echo "== Autotest ELF HEADER =="

    ./Options_and_debug_example -t "$FILEA" | tail -n 19 > "$MINE"
    arm-none-eabi-readelf -h "$FILEA" | tail -n 19 > "$READELF"

    echo "===== DIFF ====="
    diff -u -w "$READELF" "$MINE"
    ;;

  -S)
    echo "== Autotest SECTION HEADERS =="

    # correction: redirections manquantes dans ton script d'origine
    ./Options_and_debug_example -S "$FILEA" \
      | grep -E '^[[:space:]]\[' \
      | tr -s ' ' > "$MINE"

    arm-none-eabi-readelf --wide -S "$FILEA" \
      | grep -E '^[[:space:]]\[' \
      | tr -s ' ' > "$READELF"

    echo "===== DIFF ====="
    diff -u -w "$READELF" "$MINE"
    ;;

  -f)
    [ -n "$FILEB" ] || fail "Usage: $0 -f <fileA.o> <fileB.o> <out.o>"
    [ -n "$OUTFILE" ] || fail "Usage: $0 -f <fileA.o> <fileB.o> <out.o>"

    echo "== Autotest ETAPE 6 (Fusion sections, par section) =="

    ./Options_and_debug_example -f "$FILEA" "$FILEB" "$OUTFILE" || fail "Fusion -f a échoué"
    [ -f "$OUTFILE" ] || fail "Fichier sortie introuvable: $OUTFILE"
    pass "Fichier sortie créé: $OUTFILE"

    # readelf -S sans warning
    arm-none-eabi-readelf -S --wide "$OUTFILE" 2>&1 | grep -q "Warning:" && fail "readelf -S affiche des warnings"
    pass "readelf -S sans warnings"

    # construire listes sections utiles
    liste_sections_utiles "$FILEA" > "$SECA"
    liste_sections_utiles "$FILEB" > "$SECB"

    # union des noms
    awk '{print $1}' "$SECA" "$SECB" | sort -u > "$SECU"

    echo
    echo "== Tests par section (règles étape 6) =="

    while IFS= read -r secname; do
      [ -n "$secname" ] || continue

      # ignorer .shstrtab (reconstruite)
      if [ "$secname" = ".shstrtab" ]; then
        # on vérifie juste qu'elle existe
        section_existe "$OUTFILE" ".shstrtab" || fail ".shstrtab absente"
        pass ".shstrtab présente (reconstruite, pas comparée)"
        continue
      fi

      # présence dans A et/ou B
      typeA=$(get_type "$SECA" "$secname")
      typeB=$(get_type "$SECB" "$secname")

      inA=0; inB=0
      [ -n "$typeA" ] && inA=1
      [ -n "$typeB" ] && inB=1

      # doit exister dans out
      section_existe "$OUTFILE" "$secname" || fail "Section manquante dans out: $secname"

      # tailles
      out_size_hex=$(arm-none-eabi-readelf -S --wide "$OUTFILE" | awk -v s="$secname" '$0 ~ ("[[:space:]]" s "([[:space:]]|$)") {print $6; exit}')
      [ -n "$out_size_hex" ] || fail "Impossible de lire la taille out pour $secname"

      # cas 1: section dans A et B
      if [ "$inA" -eq 1 ] && [ "$inB" -eq 1 ]; then
        sizeA_hex=$(get_size_hex "$SECA" "$secname")
        sizeB_hex=$(get_size_hex "$SECB" "$secname")
        sizeA_dec=$(hex_to_dec "$sizeA_hex")
        sizeB_dec=$(hex_to_dec "$sizeB_hex")
        out_dec=$(hex_to_dec "$out_size_hex")

        # PROGBITS : concat A||B
        if [ "$typeA" = "PROGBITS" ] && [ "$typeB" = "PROGBITS" ]; then
          expect=$((sizeA_dec + sizeB_dec))
          [ "$out_dec" -eq "$expect" ] || fail "$secname: taille out != A+B (out=$out_size_hex A=$sizeA_hex B=$sizeB_hex)"

          ha=$(dump_hex_stream "$FILEA" "$secname")
          hb=$(dump_hex_stream "$FILEB" "$secname")
          ho=$(dump_hex_stream "$OUTFILE" "$secname")

          [ "$ho" = "${ha}${hb}" ] || fail "$secname: contenu out != concat(A||B)"
          pass "$secname (PROGBITS): taille=A+B et contenu concat OK"
          continue
        fi

        # NOBITS : somme des tailles (pas de dump)
        if [ "$typeA" = "NOBITS" ] && [ "$typeB" = "NOBITS" ]; then
          expect=$((sizeA_dec + sizeB_dec))
          [ "$out_dec" -eq "$expect" ] || fail "$secname (NOBITS): taille out != A+B (out=$out_size_hex A=$sizeA_hex B=$sizeB_hex)"
          pass "$secname (NOBITS): taille=A+B OK"
          continue
        fi

        # autres types : pas de concat à l'étape 6 => on garde A seulement
        # on vérifie taille out == taille A ; si c'est PROGBITS on vérifie aussi le contenu
        [ "$out_dec" -eq "$sizeA_dec" ] || fail "$secname ($typeA/$typeB): attendu taille out == taille A"
        if [ "$typeA" = "PROGBITS" ]; then
          ha=$(dump_hex_stream "$FILEA" "$secname")
          ho=$(dump_hex_stream "$OUTFILE" "$secname")
          [ "$ho" = "$ha" ] || fail "$secname: attendu contenu out == contenu A (pas de concat)"
        fi
        pass "$secname ($typeA/$typeB): pas de concat (out==A) OK"
        continue
      fi

      # cas 2: section uniquement dans A
      if [ "$inA" -eq 1 ] && [ "$inB" -eq 0 ]; then
        sizeA_hex=$(get_size_hex "$SECA" "$secname")
        sizeA_dec=$(hex_to_dec "$sizeA_hex")
        out_dec=$(hex_to_dec "$out_size_hex")
        [ "$out_dec" -eq "$sizeA_dec" ] || fail "$secname: taille out != taille A"

        if [ "$typeA" = "PROGBITS" ]; then
          ha=$(dump_hex_stream "$FILEA" "$secname")
          ho=$(dump_hex_stream "$OUTFILE" "$secname")
          [ "$ho" = "$ha" ] || fail "$secname: contenu out != contenu A"
        fi
        pass "$secname (uniquement A): taille+contenu OK"
        continue
      fi

      # cas 3: section uniquement dans B
      if [ "$inA" -eq 0 ] && [ "$inB" -eq 1 ]; then
        sizeB_hex=$(get_size_hex "$SECB" "$secname")
        sizeB_dec=$(hex_to_dec "$sizeB_hex")
        out_dec=$(hex_to_dec "$out_size_hex")
        [ "$out_dec" -eq "$sizeB_dec" ] || fail "$secname: taille out != taille B"

        if [ "$typeB" = "PROGBITS" ]; then
          hb=$(dump_hex_stream "$FILEB" "$secname")
          ho=$(dump_hex_stream "$OUTFILE" "$secname")
          [ "$ho" = "$hb" ] || fail "$secname: contenu out != contenu B"
        fi
        pass "$secname (uniquement B): taille+contenu OK"
        continue
      fi

      # si on arrive là, il y a un problème de logique
      fail "$secname: état inattendu (ni dans A ni dans B ?)"
    done < "$SECU"

    echo
    pass "== OK: tous les tests étape 6 ont passé =="
    ;;

  *)
    echo "Option inconnue: $OPTION"
    echo "Options valides: -S, -t, -f"
    exit 1
    ;;
esac
